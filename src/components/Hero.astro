---
import SplineIsland from './SplineIsland.tsx';
---

<section class="hero min-h-screen flex flex-col lg:flex-row items-center justify-center px-4 py-20 bg-gradient-to-br from-slate-900 via-indigo-900/30 to-black relative overflow-hidden" transition:name="hero" transition:persist>
  <!-- Spline BG Island (client:idle per astro-framework) -->
  <SplineIsland client:idle scene="https://prod.spline.design/banana-dev-cyberpunk.scene" badgeText="3D Interactive" class="absolute inset-0 w-full h-full -z-10 object-cover opacity-70" />

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto text-center lg:text-left lg:ml-20 space-y-8">
    <div class="space-y-6">
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-black bg-gradient-to-r from-white via-blue-100 to-purple-300 bg-clip-text text-transparent leading-tight drop-shadow-2xl">
        Peter<br>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-purple-500 to-pink-500">DevOps Engineer</span>
      </h1>
      <p class="text-xl md:text-2xl lg:text-3xl font-light text-slate-300 max-w-2xl leading-relaxed">
        Kubernetes | Automation | Cloud Infrastructure | Astro + Spline 3D Portfolio 2026
      </p>
    </div>
    <div class="flex flex-col sm:flex-row gap-6 pt-12">
      <a href="/projects" class="group btn-primary px-12 py-5 bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-700 hover:to-blue-700 rounded-2xl text-xl font-semibold shadow-2xl hover:shadow-purple-500/50 transform hover:-translate-y-1 transition-all duration-500 backdrop-blur-md border border-white/10">
        Proyectos <span class="ml-2 group-hover:translate-x-2 transition-transform">→</span>
      </a>
      <a href="/contact" class="px-12 py-5 border-2 border-white/30 rounded-2xl text-xl font-semibold hover:bg-white/10 transition-all duration-300 backdrop-blur-md hover:border-white/50">
        Contáctame
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 w-20 h-20 animate-pulse">
    <svg class="w-full h-full text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<style>
  /* Scoped Tailwind + custom (astro-framework styling) */
  @import '../styles/global.css';  /* Tailwind base */
</style>
